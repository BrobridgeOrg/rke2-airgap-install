# ── Bundle ────────────────────────────────────────────────────────────────────
RKE2_VERSION=v1.35.3+rke2r1
ARCH=amd64
OUT_DIR=output
ARTIFACTS_BASE_URL=               # default: https://github.com/rancher/rke2/releases/download

# ── RPM repo (RHEL/CentOS only) ───────────────────────────────────────────────
LINUX_MAJOR=9

# ── Node ──────────────────────────────────────────────────────────────────────
ROLE=server                    # server | agent
TOKEN=my-secret-token
NODE_NAME=rke2-server-01
NODE_IP=192.168.1.10
SERVER_URL=                    # required for agent and additional server, e.g. https://192.168.1.10:9345

# ── Networking ────────────────────────────────────────────────────────────────
CNI=canal                      # canal | cilium | calico | none
INGRESS=traefik                # traefik | nginx | none
TLS_SANS=                      # appended to NODE_NAME and NODE_IP, e.g. "vip.example.com 10.0.0.100"

# ── Security ──────────────────────────────────────────────────────────────────
CIS=true                      # enable CIS hardening profile

# ── Advanced (server only) ────────────────────────────────────────────────────
DISABLE_CLOUD_CONTROLLER=true
DISABLE_KUBE_PROXY=false       # recommended when using Cilium
REGISTRY=                      # private registry for air-gap, e.g. registry.example.com
